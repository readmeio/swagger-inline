{
  "name": "swagger-inline",
  "version": "7.0.1",
  "description": "Generate an OpenAPI/Swagger definition from inline comments.",
  "keywords": [
    "api",
    "comments",
    "docs",
    "documentation",
    "inline",
    "readmeio",
    "swagger"
  ],
  "homepage": "https://github.com/readmeio/swagger-inline#readme",
  "bugs": {
    "url": "https://github.com/readmeio/swagger-inline/issues"
  },
  "license": "ISC",
  "author": "Readme.io",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/readmeio/swagger-inline.git"
  },
  "bin": {
    "swagger-inline": "bin/swagger-inline"
  },
  "main": "src/index.js",
  "scripts": {
    "format": "npx oxlint --fix && npx oxfmt --write",
    "lint": "npx oxlint && npx oxfmt --check",
    "pretest": "npm run lint",
    "test": "vitest --coverage"
  },
  "dependencies": {
    "commander": "^6.0.0",
    "globby": "^11.0.1",
    "js-yaml": "^4.2.0",
    "multilang-extract-comments": "^0.4.0"
  },
  "devDependencies": {
    "@readme/oxlint-config": "^1.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "vitest": "^4.1.8"
  },
  "prettier": "@readme/eslint-config/prettier",
  "engines": {
    "node": ">=22"
  }
}
